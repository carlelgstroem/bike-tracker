# ---- Munin configuration ----
# Copy to .env and fill in. .env is git-ignored.

# HTTP server
PORT=3000
# Host to bind. 127.0.0.1 keeps it on localhost only (recommended on your Mac).
# Use 0.0.0.0 later on syscall-z if you want LAN access.
HOST=127.0.0.1

# Public base URL of this server, used to build the OAuth redirect URI.
# Must EXACTLY match a redirect URI registered in the WHOOP Developer Dashboard.
BASE_URL=http://localhost:3000

# ---- WHOOP API v2 OAuth ----
# Register an app at https://developer.whoop.com and paste the credentials here.
# In the dashboard, add this exact redirect URI: ${BASE_URL}/auth/whoop/callback
#   e.g. http://localhost:3000/auth/whoop/callback
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ---- Weather (Open-Meteo, no key needed) ----
# Washington, DC by default.
LATITUDE=38.9072
LONGITUDE=-77.0369
TIMEZONE=America/New_York

# ---- Storage ----
# SQLite file location. Kept under ./data so it survives restarts and is portable.
# In the container this defaults to /app/data/munin.db (mount a volume there).
DATABASE_PATH=./data/munin.db

# ---- Auth (required when hosting publicly) ----
# HTTP Basic gate. Leave AUTH_PASSWORD blank for local-only (loopback) use.
# The server REFUSES to bind a public HOST (e.g. 0.0.0.0) unless this is set,
# so your health data is never exposed unauthenticated.
AUTH_USER=munin
AUTH_PASSWORD=

# ---- Notes for cloud (Railway) ----
# Railway injects PORT and terminates TLS at its edge. Set these as service
# variables in the Railway dashboard (NOT here):
#   HOST=0.0.0.0
#   BASE_URL=https://<your-app>.up.railway.app   (your public URL)
#   AUTH_PASSWORD=<a strong password>
#   WHOOP_CLIENT_ID / WHOOP_CLIENT_SECRET
# Then register  ${BASE_URL}/auth/whoop/callback  as a redirect URI in WHOOP,
# and attach a Volume mounted at /app/data so the SQLite history persists.
